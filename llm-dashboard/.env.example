# ─────────────────────────────────────────
# LLM Token Dashboard — Environment Template
# ─────────────────────────────────────────
# Copy this file to .env and fill in your keys
# cp .env.example .env
#
# NEVER commit .env to GitHub
# Your keys never leave your machine
# ─────────────────────────────────────────

# SUPABASE — create free account at supabase.com
# Project Settings → API → Project URL and anon key
SUPABASE_URL=your-supabase-url-here
SUPABASE_KEY=your-supabase-publishable-key-here

# ─────────────────────────────────────────
# LLM PROVIDER KEYS
# Add only the ones you use
# ─────────────────────────────────────────

# OpenAI — platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-key-here

# Anthropic Claude — console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-key-here

# Google Gemini — aistudio.google.com
GEMINI_API_KEY=your-gemini-key-here

# Groq — console.groq.com (free tier available)
GROQ_API_KEY=your-groq-key-here

# Mistral — console.mistral.ai (free tier available)
MISTRAL_API_KEY=your-mistral-key-here

# Cohere — dashboard.cohere.com (free tier available)
COHERE_API_KEY=your-cohere-key-here

# Together AI — api.together.xyz (free tier available)
TOGETHER_API_KEY=your-together-key-here

# ─────────────────────────────────────────
# PROJECT SETTINGS
# Generated automatically by setup.py
# ─────────────────────────────────────────

# Your project ID (auto generated by setup.py)
PROJECT_ID=generated-by-setup

# Optional — if you have multiple API keys
# per provider add them here
OPENAI_REAL_KEY=your-second-openai-key-here